# Base URL the browser uses to reach the backend API (public, not the
# internal docker-compose hostname -- this is a NEXT_PUBLIC_ var, inlined
# into the JS bundle at build time).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Must match backend/.env's GOOGLE_CLIENT_ID (same OAuth Web Client ID).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
