# Transcription: at least one of these enables real diarization.
ASSEMBLYAI_API_KEY=
HF_TOKEN=

# Vision judgment + topic segmentation. Both stages are skipped unless the
# key for the selected LLM_PROVIDER below is set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# anthropic (default) or openai -- which provider runs vision judgment + topic segmentation.
LLM_PROVIDER=anthropic
OPENAI_MODEL=gpt-5.4-mini

# auto: assemblyai if ASSEMBLYAI_API_KEY set, else whisper-diarized if HF_TOKEN set, else whisper
TRANSCRIPTION_ENGINE=auto
WHISPER_MODEL=base

# Postgres (self-hosted via the `postgres` docker-compose service below).
# DATABASE_URL's host/port/db name must match the `postgres` service + POSTGRES_PASSWORD.
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg2://vid2doc:change-me@postgres:5432/vid2doc

# Google OAuth Client ID (Web application, from Google Cloud Console). Only
# ID-token verification is used here -- no client secret or redirect URI
# needed. This same value also goes in frontend/.env as NEXT_PUBLIC_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=
# Signs the app-issued session JWT returned after Google verification.
# Generate a real one for prod, e.g. `openssl rand -hex 32`.
JWT_SECRET=change-me

# Frontend origin(s) allowed to call this API from a browser (comma-separated,
# exact scheme+host+port, no trailing slash). Add the production frontend
# origin here too once deployed (e.g. https://app.framewrite.cc).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend build args (docker-compose reads these from this file too, for the
# `frontend` service's build.args). Use the public URL the browser reaches
# the API at -- a real domain in prod (e.g. https://api.framewrite.cc), not
# the internal `api` compose hostname, since these calls happen client-side.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
